# ---- Configuración local (desarrollo) ----
# Puerto del servidor
PORT=4000

# Conexión a PostgreSQL.
# Local:     postgresql://usuario:clave@localhost:5432/aulavirtual
# Neon/nube: postgresql://usuario:clave@host.neon.tech/aulaviva?sslmode=require
DATABASE_URL=postgresql://usuario:clave@localhost:5432/aulavirtual

# Fuerza SSL aunque la URL no lo indique (ponlo en true si tu proveedor lo exige).
# Con Neon no hace falta: se detecta por la URL.
DATABASE_SSL=false

# Clave secreta para firmar los tokens JWT (usa una larga y aleatoria en producción).
JWT_SECRET=pon-aqui-una-clave-larga-y-secreta
JWT_EXPIRES=7d

# Entorno: development | production
NODE_ENV=development
